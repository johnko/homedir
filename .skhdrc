########## Numbers #########################################################

#         ctrl + alt + cmd - 1 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 1 : # Hammerspoon switcher
#         ctrl + alt + cmd - 2 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 2 : # Hammerspoon switcher
#         ctrl + alt + cmd - 3 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 3 : # Hammerspoon switcher
#         ctrl + alt + cmd - 4 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 4 : # Hammerspoon switcher
#         ctrl + alt + cmd - 5 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 5 : # Hammerspoon switcher
#         ctrl + alt + cmd - 6 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 6 : # Hammerspoon switcher
#         ctrl + alt + cmd - 7 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 7 : # Hammerspoon switcher
#         ctrl + alt + cmd - 8 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 8 : # Hammerspoon switcher
#         ctrl + alt + cmd - 9 : # Hammerspoon switcher
# shift + ctrl + alt + cmd - 9 : # Hammerspoon switcher

########## Row Q #########################################################

          ctrl + alt + cmd - q : yabai -m window --grid 1:2:0:0:1:1
  shift + ctrl + alt + cmd - q : yabai -m window --grid 2:2:0:0:1:1
          ctrl + alt + cmd - w : osascript ~/.osascripts/terminal-brew-update.scpt
  shift + ctrl + alt + cmd - w : osascript ~/.osascripts/terminal-brew-prune.scpt
          ctrl + alt + cmd - e : yabai -m window --grid 1:2:1:0:1:1
  shift + ctrl + alt + cmd - e : yabai -m window --grid 2:2:1:0:1:1

          ctrl + alt + cmd - r : bash ~/bin/macos-reset-window-layout.sh
                           f14 : bash ~/bin/macos-reset-window-layout.sh
# shift + ctrl + alt + cmd - r : echo
#                  shift - f14 : # macOS Remove Window from Set

          ctrl + alt + cmd - t : osascript ~/.osascripts/toggle-terminal.scpt
                           f15 : osascript ~/.osascripts/toggle-terminal.scpt
  shift + ctrl + alt + cmd - t : yabai -m window --grid 1:6:1:0:4:1
                   shift - f15 : yabai -m window --grid 1:6:1:0:4:1

          ctrl + alt + cmd - y : skhd --restart-service && yabai --restart-service
                           f16 : skhd --restart-service && yabai --restart-service
  shift + ctrl + alt + cmd - y : open -g hammerspoon://restartwindowmanager
                   shift - f16 : open -g hammerspoon://restartwindowmanager

          ctrl + alt + cmd - u : osascript ~/.osascripts/toggle-googlecalendar.scpt
                           f17 : osascript ~/.osascripts/toggle-googlecalendar.scpt
  shift + ctrl + alt + cmd - u : yabai -m window --grid 16:1:0:0:1:4
                   shift - f17 : yabai -m window --grid 16:1:0:0:1:4

          ctrl + alt + cmd - i : open -a "iPhone Mirroring"
                           f18 : open -a "iPhone Mirroring"
  shift + ctrl + alt + cmd - i : yabai -m window --grid 2:3:1:0:1:1
                   shift - f18 : yabai -m window --grid 2:3:1:0:1:1

          ctrl + alt + cmd - o : open -a "System Settings"
                           f19 : open -a "System Settings"
# shift + ctrl + alt + cmd - o : echo
#                  shift - f19 : # macOS Emoji & Symbols

          ctrl + alt + cmd - p : osascript ~/.osascripts/toggle-1password.scpt
  shift + ctrl + alt + cmd - p : yabai -m window --grid 4:4:1:1:2:2
#3:3:1:1:1:1

########## Row A #########################################################

#         ctrl + alt + cmd - a : echo
  shift + ctrl + alt + cmd - a : yabai -m window --grid 2:2:0:1:1:1
#         ctrl + alt + cmd - s : echo
  shift + ctrl + alt + cmd - s : osascript ~/.osascripts/terminal-toggle-sudo.scpt
#         ctrl + alt + cmd - d : echo
  shift + ctrl + alt + cmd - d : yabai -m window --grid 2:2:1:1:1:1
          ctrl + alt + cmd - f : osascript ~/.osascripts/toggle-firefox.scpt
  shift + ctrl + alt + cmd - f : yabai -m window --grid 1:1:0:0:1:1
          ctrl + alt + cmd - g : osascript ~/.osascripts/toggle-googlechrome.scpt
  shift + ctrl + alt + cmd - g : yabai -m window --grid 1:4:1:0:2:1
          ctrl + alt + cmd - h : yabai -m window --grid 1:4:1:0:2:1
#         ctrl + alt + cmd - h : yabai -m space --rotate 90
  shift + ctrl + alt + cmd - h : yabai -m window --grid 1:1:0:0:1:1
# shift + ctrl + alt + cmd - h : yabai -m window --toggle split
          ctrl + alt + cmd - j : osascript ~/.osascripts/toggle-messages.scpt
  shift + ctrl + alt + cmd - j : yabai -m window --grid 2:3:2:0:1:1
          ctrl + alt + cmd - k : osascript ~/.osascripts/toggle-signal.scpt
  shift + ctrl + alt + cmd - k : yabai -m window --grid 2:3:1:1:1:1
          ctrl + alt + cmd - l : osascript ~/.osascripts/toggle-line.scpt
  shift + ctrl + alt + cmd - l : yabai -m window --grid 2:3:2:1:1:1

########## Row Z #########################################################

          ctrl + alt + cmd - z : osascript ~/.osascripts/toggle-cursor.scpt
  shift + ctrl + alt + cmd - z : yabai -m window --grid 40:2:0:2:1:35
          ctrl + alt + cmd - x : osascript ~/.osascripts/toggle-codex.scpt
  shift + ctrl + alt + cmd - x : yabai -m window --grid 40:2:1:2:1:35
          ctrl + alt + cmd - c : osascript ~/.osascripts/toggle-slack.scpt
  shift + ctrl + alt + cmd - c : yabai -m window --grid 16:1:0:4:1:12
          ctrl + alt + cmd - v : osascript ~/.osascripts/toggle-vscode.scpt
  shift + ctrl + alt + cmd - v : yabai -m window --grid 40:3:0:1:2:35
          ctrl + alt + cmd - b : osascript ~/.osascripts/toggle-brave.scpt
  shift + ctrl + alt + cmd - b : yabai -m window --grid 7:3:0:2:1:5
          ctrl + alt + cmd - n : bash ~/bin/macos-move-window-to-next-screen.sh
  shift + ctrl + alt + cmd - n : osascript ~/.osascripts/terminal-nosleep.scpt
          ctrl + alt + cmd - m : osascript ~/.osascripts/toggle-googlemeet.scpt
  shift + ctrl + alt + cmd - m : yabai -m window --grid 40:3:1:1:2:35

########## Right Group Arrows #########################################################

#         ctrl + alt + cmd - up    : yabai -m window --focus north
          ctrl + alt + cmd - up    : osascript ~/.osascripts/terminal-toggle-audio.scpt
#         ctrl + alt + cmd - down  : yabai -m window --focus south
          ctrl + alt + cmd - down  : osascript ~/.osascripts/volume-50.scpt
#         ctrl + alt + cmd - left  : yabai -m window --focus west
          ctrl + alt + cmd - left  : osascript ~/.osascripts/volume-25.scpt
#         ctrl + alt + cmd - right : yabai -m window --focus east
          ctrl + alt + cmd - right : osascript ~/.osascripts/volume-75.scpt
# shift + ctrl + alt + cmd - up    : yabai -m window --swap north
  shift + ctrl + alt + cmd - up    : yabai -m window --grid 2:1:0:0:1:1
# shift + ctrl + alt + cmd - down  : yabai -m window --swap south
  shift + ctrl + alt + cmd - down  : yabai -m window --grid 2:1:0:1:1:1
# shift + ctrl + alt + cmd - left  : yabai -m window --swap west
  shift + ctrl + alt + cmd - left  : yabai -m window --grid 1:2:0:0:1:1
# shift + ctrl + alt + cmd - right : yabai -m window --swap east
  shift + ctrl + alt + cmd - right : yabai -m window --grid 1:2:1:0:1:1

########## Group Function Keys #########################################################

                            f3 : open -a "Mission Control"
#                           f4 : open -a "Mission Control" --args 2 # macOS Application Expose
#                           f5 : open -a "Mission Control" --args 1 # macOS Show Desktop
#                           f6 : # macOS Turn Do Not Disturb on/off
#                           f7 : # macOS Toggle StageManager on/off
                           f11 : osascript ~/.osascripts/terminal-toggle-sudo.scpt
                           f12 : osascript ~/.osascripts/terminal-brew-update.scpt
                           f13 : bash ~/bin/macos-move-to-top-of-screen.sh

########## Left Group Convenient Keys #########################################################

          ctrl + alt + cmd - tab : yabai -m window --grid 1:6:1:0:4:1
# shift + ctrl + alt + cmd - tab : # Hammerspoon windowpicker

# 0x32 is `
#         ctrl + alt + cmd - 0x32 : # macOS Show Notification Center
  shift + ctrl + alt + cmd - 0x32 : bash ~/bin/macos-move-to-top-of-screen.sh

